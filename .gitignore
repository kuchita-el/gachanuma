# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/playwright-report
/test-results
/.playwright-mcp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code (個人設定のみignore。team共有設定は .claude/settings.json として将来追加可能)
.claude/settings.local.json
.claude/worktrees/

# 作業用プランファイル（Issue/ロードマップの下書き。コミット不要）
/docs/plans/
